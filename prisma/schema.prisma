
generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
}

model User {
  id           String    @id @default(uuid())
  name         String
  email        String    @unique
  password     String
  role         UserRole  @default(USER)
  refreshToken String?
  createdAt    DateTime  @default(now())
  products     Product[]
}

model Product {
  id        String   @id @default(uuid())
  name      String
  price     Float
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
